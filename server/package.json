{
  "name": "ferncot-mo",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/server.js",
    "dev": "nodemon ./server.ts",
    "prepare": "npm run build",
    "migration:generate": "npm run typeorm migration:generate -- -d ./config/database.ts",
    "migration:run": "npm run typeorm migration:run -- -d ./config/database.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d ./config/database.ts",
    "dev:watch": "concurrently \"tsc -w\" \"nodemon dist/server.js\"",
    "typeorm": "typeorm-ts-node-commonjs",
    "seed:permissions": "ts-node scripts/seedPermissions.ts",
    "seed:roles": "ts-node scripts/seedRoles.ts",
    "seed:categories": "ts-node scripts/seedCategories.ts",
    "assign:admin": "ts-node scripts/assignAdminRole.ts",
    "clear:inventory": "ts-node scripts/clearInventory.ts",
    "fix:enums": "ts-node scripts/fix-enums.ts",
    "maintenance:cron": "ts-node scripts/run-maintenance-cron.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.10.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.3",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.31",
    "@types/nodemailer": "^6.4.17",
    "@types/paystack": "^2.0.4",
    "@types/pg": "^8.16.0",
    "@types/speakeasy": "^2.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
