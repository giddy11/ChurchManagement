{
  "name": "church-be",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node ./index.ts",
    "dev": "nodemon ./server.ts",
    "migration:generate": "npm run typeorm migration:generate -- -d ./config/database.ts",
    "migration:run": "npm run typeorm migration:run -- -d ./config/database.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d ./config/database.ts",
    "dev:watch": "concurrently \"tsc -w\" \"nodemon dist/server.js\"",
    "typeorm": "typeorm-ts-node-commonjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.30",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
